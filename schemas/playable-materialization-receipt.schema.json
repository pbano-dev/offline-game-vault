{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offline-game-vault.invalid/schemas/playable-materialization-receipt.schema.json",
  "title": "Offline Game Vault playable materialization receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "receipt_id",
    "capsule_id",
    "profile_id",
    "profile_status",
    "backend",
    "created_at",
    "orchestrator_version",
    "destination",
    "contract_digest",
    "objects",
    "layout",
    "paths",
    "prefix_operations",
    "runner_symlink_count",
    "protected_files",
    "launch",
    "receipts_directory",
    "state",
    "removal",
    "limitations",
    "complete"
  ],
  "properties": {
    "schema": {
      "const": 0
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^playable-materialization-[0-9a-f-]{36}$"
    },
    "capsule_id": {
      "$ref": "#/$defs/id"
    },
    "profile_id": {
      "$ref": "#/$defs/id"
    },
    "profile_status": {
      "enum": [
        "verified",
        "candidate",
        "experimental",
        "not_tested"
      ]
    },
    "backend": {
      "const": "wine"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "orchestrator_version": {
      "type": "string",
      "minLength": 1
    },
    "destination": {
      "const": "."
    },
    "contract_digest": {
      "$ref": "#/$defs/digest"
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "digest",
          "destination",
          "strategy",
          "verified"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "$ref": "#/$defs/digest"
          },
          "destination": {
            "$ref": "#/$defs/relativePath"
          },
          "strategy": {
            "enum": [
              "extract",
              "copy",
              "copy_tree"
            ]
          },
          "verified": {
            "const": true
          }
        }
      }
    },
    "layout": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "object",
          "source",
          "destination"
        ],
        "properties": {
          "object": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "$ref": "#/$defs/relativePath"
          },
          "destination": {
            "$ref": "#/$defs/relativePath"
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prefix",
        "runner",
        "wine",
        "wineserver",
        "entrypoint",
        "working_directory",
        "runtime",
        "launcher",
        "uninstaller",
        "portable_runtime"
      ],
      "properties": {
        "prefix": {
          "$ref": "#/$defs/relativePath"
        },
        "runner": {
          "$ref": "#/$defs/relativePath"
        },
        "wine": {
          "$ref": "#/$defs/relativePath"
        },
        "wineserver": {
          "$ref": "#/$defs/relativePath"
        },
        "entrypoint": {
          "$ref": "#/$defs/relativePath"
        },
        "working_directory": {
          "$ref": "#/$defs/relativePath"
        },
        "runtime": {
          "$ref": "#/$defs/relativePath"
        },
        "launcher": {
          "$ref": "#/$defs/relativePath"
        },
        "uninstaller": {
          "$ref": "#/$defs/relativePath"
        },
        "portable_runtime": {
          "$ref": "#/$defs/relativePath"
        }
      }
    },
    "prefix_operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "path"
        ],
        "properties": {
          "type": {
            "enum": [
              "mkdir",
              "symlink"
            ]
          },
          "path": {
            "$ref": "#/$defs/relativePath"
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "runner_symlink_count": {
      "type": "integer",
      "minimum": 0
    },
    "protected_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "digest",
          "size",
          "verified"
        ],
        "properties": {
          "path": {
            "$ref": "#/$defs/relativePath"
          },
          "digest": {
            "$ref": "#/$defs/digest"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "verified": {
            "const": true
          }
        }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoint",
        "working_directory",
        "arguments",
        "environment",
        "network"
      ],
      "properties": {
        "entrypoint": {
          "$ref": "#/$defs/relativePath"
        },
        "working_directory": {
          "$ref": "#/$defs/relativePath"
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "network": {
          "enum": [
            "allowed",
            "host_default"
          ]
        }
      }
    },
    "receipts_directory": {
      "$ref": "#/$defs/relativePath"
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_count",
        "restored",
        "source_backup_id",
        "baseline_receipt",
        "baseline_receipt_digest",
        "restore_receipt"
      ],
      "properties": {
        "item_count": {
          "type": "integer",
          "minimum": 0
        },
        "restored": {
          "type": "boolean"
        },
        "source_backup_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "baseline_receipt": {
          "anyOf": [
            {
              "$ref": "#/$defs/relativePath"
            },
            {
              "type": "null"
            }
          ]
        },
        "baseline_receipt_digest": {
          "anyOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "restore_receipt": {
          "anyOf": [
            {
              "$ref": "#/$defs/relativePath"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "removal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safe_to_remove",
        "must_preserve"
      ],
      "properties": {
        "safe_to_remove": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        },
        "must_preserve": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "complete": {
      "const": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:[\\\\/])"
      },
      "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    }
  }
}
