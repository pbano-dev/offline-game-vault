{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:offline-game-vault:schema:vault-inventory:0",
  "title": "Offline Game Vault deterministic inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "algorithm",
    "object_count",
    "total_bytes",
    "objects"
  ],
  "properties": {
    "schema": {
      "const": 0
    },
    "algorithm": {
      "const": "sha256"
    },
    "object_count": {
      "type": "integer",
      "minimum": 0
    },
    "total_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "digest",
          "path",
          "bytes"
        ],
        "properties": {
          "digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "path": {
            "type": "string",
            "pattern": "^objects/sha256/[0-9a-f]{2}/[0-9a-f]{2}/[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
