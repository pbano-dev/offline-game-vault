{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offline-game-vault.invalid/schemas/state-export.schema.json",
  "title": "Offline Game Vault portable state export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "kind",
    "export_id",
    "capsule_id",
    "profile_id",
    "created_at",
    "baseline_backup_id",
    "item_count",
    "changed_count",
    "items",
    "verified",
    "complete"
  ],
  "properties": {
    "schema": {
      "const": 0
    },
    "kind": {
      "const": "ogv-state-export"
    },
    "export_id": {
      "type": "string",
      "pattern": "^state-export-[0-9a-f]{32}$"
    },
    "capsule_id": {
      "$ref": "#/$defs/id"
    },
    "profile_id": {
      "$ref": "#/$defs/id"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "baseline_backup_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "changed_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "declared_path",
          "kind",
          "sensitive",
          "required",
          "present",
          "entry_type",
          "payload_path",
          "file_count",
          "directory_count",
          "bytes",
          "entries",
          "changed_from_baseline"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "declared_path": {
            "$ref": "#/$defs/relativePath"
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "sensitive": {
            "type": "boolean"
          },
          "required": {
            "type": "boolean"
          },
          "present": {
            "type": "boolean"
          },
          "entry_type": {
            "enum": [
              "file",
              "directory",
              "missing"
            ]
          },
          "payload_path": {
            "anyOf": [
              {
                "$ref": "#/$defs/relativePath"
              },
              {
                "type": "null"
              }
            ]
          },
          "file_count": {
            "type": "integer",
            "minimum": 0
          },
          "directory_count": {
            "type": "integer",
            "minimum": 0
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "changed_from_baseline": {
            "type": "boolean"
          }
        }
      }
    },
    "verified": {
      "const": true
    },
    "complete": {
      "const": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:[\\\\/])"
      },
      "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    }
  }
}
