{
  "$defs": {
    "digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "embeddedArtifact": {
      "additionalProperties": false,
      "properties": {
        "container_object": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "id": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        "license_note": {
          "type": "string"
        },
        "roles": {
          "items": {
            "enum": [
              "original",
              "derived",
              "configuration",
              "save",
              "tool",
              "media",
              "documentation",
              "other"
            ]
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "size": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "digest",
        "roles",
        "container_object"
      ],
      "type": "object"
    },
    "object": {
      "additionalProperties": false,
      "properties": {
        "archive_path": {
          "$ref": "#/$defs/relativePath"
        },
        "description": {
          "type": "string"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "format": {
          "enum": [
            "file",
            "directory",
            "tar",
            "tar.gz",
            "tar.zst",
            "zip",
            "flatpak_repo",
            "other"
          ]
        },
        "id": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        "license_note": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "roles": {
          "items": {
            "enum": [
              "game_payload",
              "original",
              "derived",
              "prefix_baseline",
              "save",
              "configuration",
              "runner",
              "runtime",
              "tool",
              "media",
              "documentation",
              "other"
            ]
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "shared": {
          "default": false,
          "type": "boolean"
        },
        "size": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "digest",
        "roles",
        "format",
        "required"
      ],
      "type": "object"
    },
    "playable": {
      "additionalProperties": false,
      "properties": {
        "backend": {
          "const": "wine"
        },
        "layout": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "destination": {
                "$ref": "#/$defs/relativePath"
              },
              "object": {
                "minLength": 1,
                "type": "string"
              },
              "source": {
                "$ref": "#/$defs/relativePath"
              }
            },
            "required": [
              "object",
              "source",
              "destination"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "paths": {
          "additionalProperties": false,
          "properties": {
            "launcher": {
              "$ref": "#/$defs/relativePath"
            },
            "prefix": {
              "$ref": "#/$defs/relativePath"
            },
            "runner": {
              "$ref": "#/$defs/relativePath"
            },
            "runtime": {
              "$ref": "#/$defs/relativePath"
            },
            "uninstaller": {
              "$ref": "#/$defs/relativePath"
            },
            "wine": {
              "$ref": "#/$defs/relativePath"
            },
            "wineserver": {
              "$ref": "#/$defs/relativePath"
            }
          },
          "required": [
            "prefix",
            "runner",
            "wine",
            "wineserver",
            "runtime",
            "launcher",
            "uninstaller"
          ],
          "type": "object"
        },
        "prefix_operations": {
          "items": {
            "oneOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "$ref": "#/$defs/relativePath"
                  },
                  "type": {
                    "const": "mkdir"
                  }
                },
                "required": [
                  "type",
                  "path"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "$ref": "#/$defs/relativePath"
                  },
                  "target": {
                    "minLength": 1,
                    "not": {
                      "pattern": "^(?:/|[A-Za-z]:[\\\\/])"
                    },
                    "type": "string"
                  },
                  "type": {
                    "const": "symlink"
                  }
                },
                "required": [
                  "type",
                  "path",
                  "target"
                ],
                "type": "object"
              }
            ]
          },
          "type": "array"
        },
        "protected_files": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "$ref": "#/$defs/digest"
              },
              "path": {
                "$ref": "#/$defs/relativePath"
              },
              "size": {
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "path",
              "digest"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "schema": {
          "const": 0
        }
      },
      "required": [
        "schema",
        "backend",
        "paths",
        "layout",
        "protected_files"
      ],
      "type": "object"
    },
    "profile": {
      "additionalProperties": false,
      "properties": {
        "acceptance_report": {
          "$ref": "#/$defs/relativePath"
        },
        "adapter": {
          "enum": [
            "bottles",
            "wine",
            "umu",
            "windows",
            "vm",
            "other"
          ]
        },
        "dependencies": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "host_contract": {
          "$ref": "#/$defs/relativePath"
        },
        "id": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        "launch": {
          "additionalProperties": false,
          "properties": {
            "arguments": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "entrypoint": {
              "$ref": "#/$defs/relativePath"
            },
            "environment": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "network": {
              "enum": [
                "isolated",
                "allowed",
                "host_default"
              ]
            },
            "working_directory": {
              "$ref": "#/$defs/relativePath"
            }
          },
          "required": [
            "entrypoint"
          ],
          "type": "object"
        },
        "notes": {
          "type": "string"
        },
        "platform": {
          "enum": [
            "linux",
            "windows"
          ]
        },
        "playable": {
          "$ref": "#/$defs/playable"
        },
        "status": {
          "enum": [
            "verified",
            "candidate",
            "experimental",
            "not_tested",
            "unavailable"
          ]
        }
      },
      "required": [
        "id",
        "platform",
        "adapter",
        "status",
        "dependencies",
        "host_contract",
        "launch"
      ],
      "type": "object"
    },
    "relativePath": {
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:[\\\\/])"
      },
      "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    },
    "stateItem": {
      "additionalProperties": false,
      "properties": {
        "backup": {
          "default": true,
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "id": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        "kind": {
          "enum": [
            "save",
            "identity",
            "configuration",
            "cache",
            "log",
            "temporary",
            "other"
          ]
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "required": {
          "default": true,
          "type": "boolean"
        },
        "sensitive": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "path",
        "kind"
      ],
      "type": "object"
    }
  },
  "$id": "https://offline-game-vault.invalid/schemas/capsule.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capsule_id": {
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "type": "string"
    },
    "documents": {
      "additionalProperties": false,
      "properties": {
        "credits": {
          "$ref": "#/$defs/relativePath"
        },
        "game_sheet": {
          "$ref": "#/$defs/relativePath"
        },
        "preserved_by": {
          "$ref": "#/$defs/relativePath"
        },
        "readme": {
          "$ref": "#/$defs/relativePath"
        }
      },
      "required": [
        "readme",
        "game_sheet",
        "credits",
        "preserved_by"
      ],
      "type": "object"
    },
    "embedded_artifacts": {
      "items": {
        "$ref": "#/$defs/embeddedArtifact"
      },
      "type": "array"
    },
    "game": {
      "additionalProperties": false,
      "properties": {
        "appid": {
          "type": [
            "integer",
            "string"
          ]
        },
        "edition": {
          "type": "string"
        },
        "language": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "preserved_version": {
          "minLength": 1,
          "type": "string"
        },
        "source_store": {
          "minLength": 1,
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "title",
        "source_store",
        "preserved_version"
      ],
      "type": "object"
    },
    "objects": {
      "description": "First-class objects only: one canonical game object plus shared runner/runtime archives. Internal critical files belong in embedded_artifacts.",
      "items": {
        "$ref": "#/$defs/object"
      },
      "minItems": 1,
      "type": "array"
    },
    "persistent_state": {
      "items": {
        "$ref": "#/$defs/stateItem"
      },
      "type": "array"
    },
    "privacy_exceptions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          },
          "scope": {
            "items": {
              "$ref": "#/$defs/relativePath"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "id",
          "reason",
          "scope"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "profiles": {
      "items": {
        "$ref": "#/$defs/profile"
      },
      "minItems": 1,
      "type": "array"
    },
    "regenerable_state": {
      "items": {
        "$ref": "#/$defs/stateItem"
      },
      "type": "array"
    },
    "sanitized_fixture": {
      "default": false,
      "type": "boolean"
    },
    "schema": {
      "const": 0
    }
  },
  "required": [
    "schema",
    "capsule_id",
    "game",
    "documents",
    "objects",
    "profiles"
  ],
  "title": "Offline Game Vault capsule",
  "type": "object"
}
