{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offline-game-vault.invalid/schemas/host-contract.schema.json",
  "title": "Offline Game Vault host contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "contract_id",
    "platform",
    "architecture",
    "filesystem"
  ],
  "properties": {
    "schema": {
      "const": 0
    },
    "contract_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "platform": {
      "enum": [
        "linux",
        "windows"
      ]
    },
    "architecture": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "x86_64",
          "aarch64",
          "x86"
        ]
      }
    },
    "filesystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_sensitive",
        "symlinks",
        "executable_bit"
      ],
      "properties": {
        "case_sensitive": {
          "enum": [
            "required",
            "preferred",
            "not_required"
          ]
        },
        "symlinks": {
          "enum": [
            "required",
            "preferred",
            "not_required"
          ]
        },
        "executable_bit": {
          "enum": [
            "required",
            "preferred",
            "not_required"
          ]
        },
        "colon_in_names": {
          "enum": [
            "required",
            "preferred",
            "not_required"
          ]
        },
        "minimum_free_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flatpak": {
          "$ref": "#/$defs/requirement"
        },
        "user_namespaces": {
          "$ref": "#/$defs/requirement"
        },
        "network_namespaces": {
          "$ref": "#/$defs/requirement"
        },
        "ntsync": {
          "$ref": "#/$defs/requirement"
        },
        "vulkan": {
          "$ref": "#/$defs/requirement"
        },
        "wayland": {
          "$ref": "#/$defs/requirement"
        },
        "x11": {
          "$ref": "#/$defs/requirement"
        },
        "audio": {
          "$ref": "#/$defs/requirement"
        },
        "python": {
          "$ref": "#/$defs/requirement"
        }
      }
    },
    "graphics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vulkan_minimum": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "required_extensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "tested_backend": {
          "enum": [
            "vulkan",
            "opengl",
            "direct3d",
            "unknown"
          ]
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level"
      ],
      "properties": {
        "level": {
          "enum": [
            "required",
            "preferred",
            "not_required",
            "unknown"
          ]
        },
        "minimum_version": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
