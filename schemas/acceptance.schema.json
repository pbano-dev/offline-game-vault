{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offline-game-vault.invalid/schemas/acceptance.schema.json",
  "title": "Offline Game Vault acceptance report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "capsule_id",
    "profile_id",
    "tested_at",
    "result",
    "tests",
    "limitations"
  ],
  "properties": {
    "schema": {
      "const": 0
    },
    "capsule_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "tested_at": {
      "type": "string",
      "format": "date"
    },
    "result": {
      "enum": [
        "passed",
        "passed_with_limitations",
        "failed",
        "incomplete"
      ]
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "not_tested",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
